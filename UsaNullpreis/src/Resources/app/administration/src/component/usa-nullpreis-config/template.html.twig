{% block usa_nullpreis_config %}
<sw-card :title="$tc('usa-nullpreis.config.title')" :isLoading="isLoading">

    <sw-entity-single-select
        entity="customer_group"
        :label="$tc('usa-nullpreis.config.customerGroupLabel')"
        :helpText="$tc('usa-nullpreis.config.customerGroupHelp')"
        :value="selectedCustomerGroupId"
        @change="selectedCustomerGroupId = $event"
        showClearableButton
    />

    <sw-entity-single-select
        entity="rule"
        :label="$tc('usa-nullpreis.config.ruleLabel')"
        :helpText="$tc('usa-nullpreis.config.ruleHelp')"
        :value="selectedRuleId"
        @change="selectedRuleId = $event"
        showClearableButton
    />

    <template #footer>
        <sw-button variant="primary" @click="onSave">
            {{ $tc('usa-nullpreis.config.save') }}
        </sw-button>
    </template>

</sw-card>
{% endblock %}
