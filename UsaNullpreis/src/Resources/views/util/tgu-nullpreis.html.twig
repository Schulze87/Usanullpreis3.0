{% set usaNullpreisActive = false %}
{% if context.currentCustomerGroup.id == usaNullpreisCustomerGroupId
    or usaNullpreisRuleId in context.ruleIds %}
    {% set usaNullpreisActive = true %}
{% endif %}

{# JS-Flag für dein Frontend #}
<script>
    document.documentElement.dataset.usaNullpreisActive = '{{ usaNullpreisActive ? "1" : "0" }}';
</script>

{# CSS nur aktiv, wenn Regel aktiv #}
{% if usaNullpreisActive %}
<style>
    .order-item-detail-summary { display: none; }
    .line-item-total-price-value { display: none; }
    .offcanvas-summary { display: none; }
    .cart-header-tax-price { display: none; }
    .cart-header-total-price { display: none; }
    .line-item-tax-price { display: none; }
    .line-item-total-price { display: none; }
    .line-item-price { display: none; }
    .line-item-unit-price-value { display: none; }
    .offcanvas-cart-tax { display: none; }
    .checkout-aside-summary { display: none; }
</style>
{% endif %}
