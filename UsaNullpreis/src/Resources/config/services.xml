<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
           https://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="UsaNullpreis\Core\Checkout\Cart\UsaNullpreisCartProcessor">
            <argument type="service" id="Shopware\Core\Checkout\Cart\Price\QuantityPriceCalculator"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="logger" on-invalid="null"/>
            <tag name="shopware.cart.processor" priority="-100"/>
            <tag name="monolog.logger" channel="UsaNullpreis"/>
        </service>

        <service id="UsaNullpreis\Twig\UsaNullpreisExtension">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <tag name="twig.extension"/>
        </service>
    </services>
</container>
